@startuml
!theme plain
skinparam rectangle {
    BackgroundColor #F8F9FA
    BorderColor #343A40
}

package "Структурный подграф" #E3F2FD {
  [Package] as PKG
  [Type (Class/Interface)] as TYP
  [Method / Function] as MTH
  [Field / Property] as FLD
}

package "Интеграционный подграф" #FFF3E0 {
  [LibraryNode] as LIB
  note right of LIB: Kafka, HTTP, \nShared Database
}

' Связи
PKG -down-> TYP : CONTAINS
TYP -down-> MTH : CONTAINS
TYP -down-> FLD : CONTAINS

MTH -right-> MTH : CALLS / THROWS
TYP -right-> TYP : INHERITS / IMPLEMENTS

MTH .down.> LIB : PRODUCES / CONSUMES \n (via IntegrationLinker)

@enduml